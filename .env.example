# URL pública de giris-agent. Imprescindible en producción.
# El formulario /contacto envía leads a ${GIRIS_AGENT_URL}/leads.
# Si no se define, el fallback es http://localhost:5318 (solo sirve en dev).
GIRIS_AGENT_URL=

# --- Descarga segura de Kenvo (secure-downloads vía Vercel Blob) ---
# Secreto para firmar los enlaces temporales de descarga (mínimo 32 caracteres).
# Lo comparten todos los productos de entrega segura (academia + Kenvo).
DOWNLOAD_TOKEN_SECRET=
# URLs de los ZIP de Kenvo en Vercel Blob. Las imprime scripts/upload-kenvo-blobs.mjs;
# pega aquí (y en las env vars de Vercel) las que devuelva. La URL no se expone al
# cliente: la descarga pasa por /api/downloads/[slug] protegida por token.
KENVO_MAC_ARM_BLOB_URL=
KENVO_MAC_INTEL_BLOB_URL=
